<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".fragment.paidserver.BuyDataFragment"
    android:orientation="vertical">

    <RelativeLayout
        android:id="@+id/nav_detail"
        android:layout_width="match_parent"
        android:layout_height="@dimen/custom_header_height"
        android:background="@color/colorPaidServer"
        android:orientation="horizontal"
        android:padding="@dimen/custom_header_padding">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="@dimen/custom_header_back_button_size"
            android:layout_height="@dimen/custom_header_back_button_size"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:padding="@dimen/custom_header_back_button_padding"
            android:scaleType="centerInside"
            android:src="@drawable/ic_back_white"
            tools:ignore="ContentDescription" />

        <LinearLayout
            android:id="@+id/ln_title"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center">

            <TextView
                android:id="@+id/txt_country"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/title_buy_data"
                android:textAlignment="center"
                android:textColor="@color/colorWhite"
                android:textSize="15sp"
                android:theme="@style/label" />
        </LinearLayout>
        <TextView
            android:layout_alignParentEnd="true"
            android:layout_gravity="center"
            android:id="@+id/txt_data_size"
            android:gravity="center"
            android:textStyle="bold"
            android:textColor="@color/colorPrimary"
            android:text="@string/calculating_data_size"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            tools:ignore="RelativeOverlap" />
    </RelativeLayout>
    <include android:id="@+id/inc_loading" layout="@layout/layout_loading_paid" />
    <androidx.recyclerview.widget.RecyclerView
        android:visibility="gone"
        android:id="@+id/rcv_sku_details"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
</LinearLayout>